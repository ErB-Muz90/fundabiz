# ─── PostgreSQL ───
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=fundabiz
POSTGRES_USER=fundabiz
POSTGRES_PASSWORD=changeme

# ─── PgBouncer ───
PGBOUNCER_PORT=6432

# ─── Redis ───
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# ─── RabbitMQ ───
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=fundabiz
RABBITMQ_PASSWORD=changeme
RABBITMQ_MANAGEMENT_PORT=15672

# ─── JWT ───
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── M-Pesa Daraja ───
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_PASSKEY=your_passkey
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://your-domain.com/api/webhooks/mpesa
MPESA_B2B_SHORTCODE=174379
MPESA_INITIATOR_NAME=testapi
MPESA_INITIATOR_PASSWORD=your_initiator_pw

# ─── Africa's Talking ───
AT_API_KEY=your_africastalking_key
AT_USERNAME=sandbox
AT_USSD_CODE=*384#
AT_SENDER_ID=FUNDABIZ

# ─── AWS S3 (KYC documents) ───
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
S3_BUCKET=fundabiz-kyc-docs
S3_PRESIGNED_TTL=15m

# ─── SMTP ───
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_key
SMTP_FROM=noreply@fundabiz.co.ke

# ─── Next.js ───
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000

# ─── Firebase (mobile push) ───
FIREBASE_PROJECT_ID=fundabiz
FIREBASE_PRIVATE_KEY=your_firebase_key
FIREBASE_CLIENT_EMAIL=firebase@fundabiz.iam.gserviceaccount.com

# ─── Credit Scoring ───
CREDIT_MIN_SALES_HISTORY_MONTHS=3
CREDIT_MAX_LOAN_TO_SALES_RATIO=0.5
CREDIT_BASE_INTEREST_RATE=0.08
